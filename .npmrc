auto-install-peers=true
strict-peer-dependencies=false

# React Native / Expo + pnpm: Metro's resolver expects a flat node_modules.
# shamefully-hoist flattens all deps to the root so Metro can resolve the
# RN/Expo toolchain (expo-modules-core, styleq, etc.). Web/admin keep a single
# React via Vite's resolve.dedupe.
shamefully-hoist=true
