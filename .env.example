# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# NOTE: `agrostock` here is a LEGACY IDENTIFIER kept on purpose. The product was
# renamed to AgroTraders, but the Compose project name, the postgres_data volume
# and the S3 bucket below still carry the old name. Renaming them orphans the
# volume and the seeded database disappears. Nothing user-facing reads these.
# Rename during a prod cutover with a dump/restore, not here.
POSTGRES_USER=agrostock
POSTGRES_PASSWORD=agrostock
POSTGRES_DB=agrostock
DATABASE_URL=postgresql://agrostock:agrostock@localhost:5544/agrostock?schema=public

# ─── Auth (JWT) ──────────────────────────────────────────────────────────
# DEV defaults below are placeholders. In production these MUST be strong, random
# and DISTINCT, or the API refuses to boot (see main.ts assertProductionSecrets).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Runtime / security ──────────────────────────────────────────────────
# NODE_ENV=production enables secret enforcement and disables Swagger.
NODE_ENV=development
# Comma-separated allowlist of browser origins permitted by CORS. Empty = allow all
# (dev only). Set this explicitly in staging/production. For agrotraders.org use:
#   CORS_ORIGINS=https://agrotraders.org,https://www.agrotraders.org,https://admin.agrotraders.org
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Set SWAGGER=1 to force-enable API docs at /api/docs in production.
SWAGGER=0

# ─── Redis (realtime / cache) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Object storage (MinIO / S3) ─────────────────────────────────────────
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=agrostock
S3_SECRET_KEY=agrostock-secret
S3_BUCKET=agrostock
S3_REGION=us-east-1
# Max chat/upload attachment size (MB).
ATTACHMENT_MAX_MB=15

# ─── Product image uploads (local filesystem, WebP) ──────────────────────
# Product images are NOT stored in S3 — they are converted to WebP and written
# to <UPLOAD_DIR> on the API host, then served at /uploads. On a host like
# Hostinger, point UPLOAD_DIR at a persistent path outside the deploy folder.
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=10
# Private document store (KYC files). NOT served on /uploads — reachable only
# through access-checked, token-signed streaming endpoints. Keep it off the
# public web root; point at a persistent path outside the deploy folder.
PRIVATE_UPLOAD_DIR=private-uploads

# ─── Ports ───────────────────────────────────────────────────────────────
# AgroTraders' API uses a dedicated port (3100) so it never clashes with other
# local projects that default to :3000. Web/admin follow VITE_API_URL below.
API_PORT=3100
WEB_PORT=5173
ADMIN_PORT=5174

# ─── Web/Admin (Vite) → must be prefixed VITE_ to be exposed ─────────────
# Vite loads this from the repo-root .env (envDir), so both apps point here.
# Uploaded product images and brand assets are served from this origin at
# /uploads, so it must be reachable from browsers in production.
# In production:  VITE_API_URL=https://api.agrotraders.org
VITE_API_URL=http://localhost:3100

# ─── Google Maps (server-side geocoding proxy) ───────────────────────────
# Powers the apps/api /geo endpoints (city name → coordinates), so the mobile/web
# clients never receive the geocoding key. Ideally a SEPARATE key from the mobile
# render key, restricted by server IP + limited to the Geocoding API in the Google
# Cloud console. Leave blank to disable geocoding (the API returns 503).
GOOGLE_MAPS_API_KEY=

# ─── Firebase (Web) → must be prefixed VITE_ to be exposed ───────────────
# From Firebase console → Project settings → Your apps → Web app → SDK config.
# These are NOT secrets — they ship in the public client bundle by design and
# only identify the project. Real protection is Firebase Security Rules, App
# Check, and restricting the API key to your domains in the Google Cloud console.
# Kept in env (not committed source) purely for hygiene / per-environment config.
# Leave blank to disable Firebase locally.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Web Push (FCM) public key: Firebase console → Project settings → Cloud
# Messaging → Web Push certificates → "Key pair". Required for browser push;
# leave blank to disable web push (the app still works, just no push prompt).
VITE_FIREBASE_VAPID_KEY=

# ─── Mobile (Expo) → must be prefixed EXPO_PUBLIC_ to be exposed ─────────
# The device/emulator cannot reach "localhost"; use the API host's LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:3100

# ─── Transactional email (SMTP) — server-side, API only ─────────────────
# Any SMTP provider (Gmail app-password, Postmark, Mailgun, SES-SMTP, …).
# Leave SMTP_HOST blank to disable email entirely — the API logs a warning at
# boot and every send becomes a no-op (nothing else breaks).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465 (implicit TLS); false for 587 (STARTTLS)
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AgroTraders <no-reply@agrotraders.org>"
MAIL_REPLY_TO=
# Absolute base URL used for links/buttons in emails and push deep-links.
APP_WEB_URL=https://agrotraders.org

# ─── Server-side push (Firebase Admin / FCM) — API only ─────────────────
# Provide the service-account JSON as a single-line string (Firebase console →
# Project settings → Service accounts → Generate new private key), OR set
# GOOGLE_APPLICATION_CREDENTIALS to a file path instead. Leave blank to disable
# push server-side (the app boots fine; sends become no-ops).
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Google Cloud Translation v2 API key (machine translation). Do NOT commit the real value.
GOOGLE_TRANSLATE_API_KEY=
