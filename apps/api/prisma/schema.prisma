// AgroTraders — Prisma schema (PostgreSQL)
generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; musl target for the alpine Docker runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  transporter
  loaderco
  worker
  admin
}

/// Granular admin capabilities. A staff account (role=admin) is authorized per
/// module by the permissions it holds; a member with `staff_manage` is treated
/// as a super-admin (bypasses every per-module check). Legacy admins are
/// backfilled with all permissions so nothing breaks.
enum AdminPermission {
  users_manage
  kyc_review
  role_requests
  products_moderate
  auctions_manage
  bids_manage
  orders_manage
  disputes_manage
  finance_manage
  transport_manage
  loaders_manage
  markets_manage
  offices_manage
  ads_moderate
  community_moderate
  support_agent
  cms_manage
  branding_manage
  audit_view
  reports_view
  staff_manage
  reviews_moderate
}

/// Which completed subject a review is anchored to. Polymorphic — exactly one of
/// the matching nullable FKs on `Review` is set (mirrors the Invoice precedent).
enum ReviewKind {
  order
  trip
  loaderjob
  assignment
  hire
}

/// What/who is being rated by a given review (drives which display surface it
/// aggregates into). Reviews are two-way: e.g. an order yields buyer→seller and
/// seller→buyer rows, distinguished by this role.
enum ReviewRole {
  seller
  buyer
  product
  transporter
  loaderco
  worker
  client
}

/// Admin moderation state. Only `visible` reviews feed public aggregates.
enum ReviewStatus {
  visible
  hidden
  removed
}

/// Product moderation lifecycle. `status` is the source of truth for admin
/// moderation; the legacy `approved`/`verified` booleans are kept in sync for
/// backward compatibility with existing public queries.
enum ProductStatus {
  pending
  live
  rejected
  hidden
}

/// Admin decision on a user's request to withdraw wallet funds.
enum PayoutStatus {
  pending
  approved
  rejected
  paid
}

enum KycStatus {
  pending
  verified
  rejected
}

enum RoleRequestStatus {
  pending
  approved
  rejected
}

enum OrderStatus {
  enquiry
  quote
  processing
  paid
  packed
  dispatched
  /// Legacy: kept so pre-lifecycle rows still read. New code never writes it.
  shipped
  in_transit
  delivered
  dispute
  cancelled
}

enum OrderEventType {
  enquiry_raised
  seller_quoted
  order_placed
  paid
  packed
  dispatched
  pickup_verified
  delivery_verified
  cancelled
  disputed
  note
}

/// `platform` = an AgroTraders transporter user (a Trip is created).
/// `external` = a third party typed in by the seller (no Trip exists).
enum DispatchMode {
  platform
  external
}

enum MarketStatus {
  pending
  approved
  rejected
}

enum AdStatus {
  pending
  approved
  rejected
}

enum BuyerBidMode {
  quote
  auction
}

enum BuyerBidStatus {
  open
  awarded
  closed
  cancelled
}

enum SellerBidStatus {
  submitted
  awarded
  rejected
  withdrawn
}

enum InvoiceKind {
  order
  trip
  loaderjob
  assignment
}

enum InvoiceStatus {
  draft
  issued
  paid
  void
}

enum RequestStatus {
  open
  quoted
  assigned
  completed
  cancelled
}

enum QuoteStatus {
  pending
  accepted
  rejected
}

enum TripStatus {
  pending
  loading
  in_transit
  delivered
  delayed
}

enum VehicleStatus {
  available
  on_trip
  maintenance
}

enum JobStatus {
  open
  assigned
  in_progress
  pending_proof
  completed
}

enum AssignmentStatus {
  assigned
  accepted
  checked_in
  completed
}

enum WorkerStatus {
  available
  on_site
  off
}

enum TxType {
  topup
  escrow_hold
  escrow_release
  payout
  refund
  withdraw
}

enum HireTargetType {
  transporter
  loaderco
  worker
}

enum HireStatus {
  pending
  accepted
  declined
  cancelled
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(buyer)
  // Additional approved roles beyond `role`. Effective roles = {role} ∪ roles.
  // Granted by an admin via an approved RoleRequest; drives the console switcher.
  roles        Role[]    @default([])
  // Staff accounts can be deactivated by an admin without deletion.
  active       Boolean   @default(true)
  // Per-module admin capabilities (only meaningful for role=admin accounts).
  adminPermissions AdminPermission[] @default([])
  country      String?
  /// Preferred UI locale (BCP-47, e.g. "ru"). Null = detect from Accept-Language.
  locale       String?
  kycStatus    KycStatus @default(pending)
  /// Per-user notification channel preferences. Shape:
  /// { categories: Record<category, { email, push, inApp }>, emailUnsubscribedAll }.
  /// Null = all-on defaults (see notification-categories.ts).
  notificationPrefs Json?
  // Denormalized rating aggregate over this user's received `visible` reviews
  // (across all roles they act in). Recomputed on every review write; used for
  // sorting/display so we never scan the review table on read paths.
  ratingAvg    Float?
  ratingCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products          Product[]          @relation("SellerProducts")
  buyerOrders       Order[]            @relation("BuyerOrders")
  sellerOrders      Order[]            @relation("SellerOrders")
  kycRecord         KycRecord?
  auctionBids       AuctionBid[]
  auctionAutoBids   AuctionAutoBid[]
  marketsCreated    Market[]           @relation("MarketCreator")
  adsReviewed       AdCampaign[]       @relation("AdReviewer")
  wallet            Wallet?
  transportRequests TransportRequest[] @relation("RequestCreator")
  transportQuotes   TransportQuote[]   @relation("QuoteTransporter")
  trips             Trip[]             @relation("TripTransporter")
  vehicles          Vehicle[]
  routes            Route[]
  teams             Team[]
  workers           Worker[]           @relation("LoadercoWorkers")
  workerProfile     Worker?            @relation("WorkerUser")
  loaderJobsCreated LoaderJob[]        @relation("JobCreator")
  loaderJobsManaged LoaderJob[]        @relation("JobLoaderco")
  roleRequests      RoleRequest[]      @relation("RequestUser")
  roleDecisions     RoleRequest[]      @relation("RequestDecider")
  payoutRequests    PayoutRequest[]    @relation("PayoutUser")
  payoutDecisions   PayoutRequest[]    @relation("PayoutDecider")

  // ── Chat systems (Community + Live Support) back-relations ──
  ownedCommunityGroups     CommunityGroup[]               @relation("CommunityGroupOwner")
  communityMemberships     CommunityGroupMember[]
  communityPosts           CommunityPost[]
  communityMessages        CommunityMessage[]
  communityReactions       CommunityMessageReaction[]
  tradeRequirements        CommunityTradeRequirement[]
  requirementResponses     CommunityRequirementResponse[]
  communityReportsMade     CommunityReport[]              @relation("CommunityReporter")
  communityReportsReviewed CommunityReport[]              @relation("CommunityReviewer")
  blocksMade               CommunityUserBlock[]           @relation("Blocker")
  blocksReceived           CommunityUserBlock[]           @relation("Blocked")
  savedPosts               CommunitySavedPost[]
  dmThreadsA               CommunityDirectThread[]        @relation("DmA")
  dmThreadsB               CommunityDirectThread[]        @relation("DmB")
  supportTickets           SupportTicket[]
  supportMessages          SupportMessage[]
  supportAssignments       SupportTicketAssignment[]      @relation("AssignmentAgent")
  supportAssignmentsMade   SupportTicketAssignment[]      @relation("AssignmentAssigner")
  supportAgentProfile      SupportAgent?
  supportNotes             SupportInternalNote[]
  supportRatings           SupportRating[]
  notifications            Notification[]
  deviceTokens             DeviceToken[]
  auditLogs                AuditLog[]
  chatAttachments          ChatAttachment[]

  // ── Profile / markets / hiring ──
  profile              Profile?
  hireRequestsMade     HireRequest[] @relation("HireRequester")
  hireRequestsReceived HireRequest[] @relation("HireTarget")

  // ── Dashboard features (ads / drivers / crew availability) ──
  adCampaigns      AdCampaign[]       @relation("AdSeller")
  drivers          Driver[]
  crewAvailability CrewAvailability[]

  // ── Loader company rate card / reviews / attendance capture ──
  loaderRates          LoaderRate[]   @relation("LoaderRates")
  loaderReviewsForCo   LoaderReview[] @relation("LoaderReviewsForCo")
  loaderReviewsByUser  LoaderReview[] @relation("LoaderReviewsByUser")
  attendanceRecorded   Attendance[]   @relation("AttendanceRecorder")

  // ── Order lifecycle / buyer bids / invoicing ──
  orderEvents      OrderEvent[] @relation("OrderEventActor")
  buyerBids        BuyerBid[]   @relation("BuyerBidBuyer")
  sellerBids       SellerBid[]  @relation("SellerBidSeller")
  invoicesIssued   Invoice[]    @relation("InvoiceIssuer")
  invoicesReceived Invoice[]    @relation("InvoiceRecipient")

  // ── Unified two-way reviews ──
  reviewsAuthored  Review[]     @relation("ReviewsAuthored")
  reviewsReceived  Review[]     @relation("ReviewsReceived")
  reviewsEdited    Review[]     @relation("ReviewAdminEditor")
}

// ── Markets & profiles ──────────────────────────────────────────

/// A physical trade market / mandi sellers attach themselves to; buyers
/// filter products and sellers by market.
/// Sellers may propose a market when theirs isn't listed. It is created
/// `pending` and stays invisible to everyone but its creator (and admins)
/// until approved — mirroring how `Product.approved` gates new listings.
/// The default is `approved` so admin-created markets go live immediately.
model Market {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  city      String?
  country   String
  region    String?
  flag      String?
  active    Boolean      @default(true)
  status    MarketStatus @default(approved)
  sort      Int          @default(0)
  createdAt DateTime     @default(now())

  createdById String?
  createdBy   User?   @relation("MarketCreator", fields: [createdById], references: [id])

  profiles     Profile[]
  products     Product[]
  translations MarketTranslation[]

  @@index([status])
}

/// Extended per-user profile. `phone`, `whatsapp` and `contactEmail` are
/// PRIVATE: only the owner and admins may ever see them — public reads go
/// through the directory module which never selects those columns.
model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  // public
  bio           String?
  location      String?
  availableFrom String?
  availableTo   String?
  timezone      String?
  languages     String?
  /// Uploaded photo ("/uploads/avatars/<uuid>.webp"). `avatarEmoji` is the fallback.
  avatarUrl     String?
  avatarEmoji   String?
  marketId      String?
  market        Market?  @relation(fields: [marketId], references: [id])
  // Operational registration data for transporters & loader companies.
  // Where the provider is based, plus the free-text city/country tags they
  // operate in and supply to (see Product.supplyCountries for the array precedent).
  originCity          String?
  originCountry       String?
  operatingCities     String[] @default([])
  operatingCountries  String[] @default([])
  supplyingCities     String[] @default([])
  supplyingCountries  String[] @default([])
  /// Minimum job size the provider will accept. minWorkHours: loader companies.
  /// minDistanceKm: transporters. minLoaders: loader companies (crew size).
  minWorkHours        Int?
  minDistanceKm       Int?
  minLoaders          Int?
  // Admin approval to appear in the public transporter/loader directory.
  listApproved  Boolean  @default(false)
  // private (admin/owner only)
  phone         String?
  whatsapp      String?
  contactEmail  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Direct "hire this transporter/loaderco/worker" request. A thin
/// negotiation object: on accept it converts into the existing
/// TransportRequest/Trip or LoaderJob/JobAssignment flows.
model HireRequest {
  id            String         @id @default(cuid())
  reference     String         @unique
  targetType    HireTargetType
  status        HireStatus     @default(pending)
  message       String?
  fromCity      String?
  toCity        String?
  cargo         String?
  location      String?
  workersNeeded Int?
  neededDate    DateTime?
  budgetCents   Int?
  /// Escrow lifecycle for the held budget: null (nothing held) | held | released | refunded.
  /// The requester's wallet is debited on send; released to the provider on
  /// completion, or refunded if the hire is declined/cancelled.
  escrowState   String?
  createdAt     DateTime       @default(now())
  decidedAt     DateTime?

  requesterId  String
  requester    User    @relation("HireRequester", fields: [requesterId], references: [id])
  targetUserId String
  targetUser   User    @relation("HireTarget", fields: [targetUserId], references: [id])
  workerId     String?
  worker       Worker? @relation(fields: [workerId], references: [id])

  transportRequestId String? @unique
  loaderJobId        String? @unique

  /// Set when a seller sources logistics from inside an order. On accept, a
  /// minted Trip is attached back to this order so dispatch/OTP still applies.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  reviews Review[] @relation("HireReviews")

  @@index([targetUserId, status])
  @@index([requesterId])
  @@index([orderId])
}

model RoleRequest {
  id          String            @id @default(cuid())
  role        Role
  status      RoleRequestStatus @default(pending)
  note        String?
  createdAt   DateTime          @default(now())
  decidedAt   DateTime?
  userId      String
  user        User              @relation("RequestUser", fields: [userId], references: [id])
  decidedById String?
  decidedBy   User?             @relation("RequestDecider", fields: [decidedById], references: [id])

  @@index([status])
}

model Category {
  id            String                @id @default(cuid())
  name          String                @unique
  slug          String                @unique
  emoji         String?
  tint          String?
  sort          Int                   @default(0)
  subcategories Subcategory[]
  products      Product[]
  buyerBids     BuyerBid[]
  translations  CategoryTranslation[]
}

model Subcategory {
  id           String                   @id @default(cuid())
  name         String
  slug         String                   @unique
  emoji        String?
  sort         Int                      @default(0)
  categoryId   String
  category     Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products     Product[]
  translations SubcategoryTranslation[]

  @@unique([categoryId, name])
}

model Product {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  emoji         String?
  /// Cover image. Always mirrors `images[0]` when the gallery is non-empty, so
  /// every existing single-image render keeps working untouched.
  imageUrl      String?
  /// Gallery, max 6, ordered — the first entry is the cover.
  images        String[]  @default([])
  grade         String?
  flag          String?
  origin        String?
  qty           String?
  moq           String?
  // Where the goods physically sit. `origin` stays the free-text/flag display
  // fallback; `city`/`country` are the structured location captured at listing.
  city          String?
  country       String?
  /// Countries the seller can supply/ship this product to. Multi-select — a
  /// seller ships to many destinations from one origin.
  supplyCountries String[] @default([])
  price         String
  // Numeric baseline (USD cents) for currency conversion; backfilled from
  // `price` where parseable. `price` stays the display fallback.
  priceCents    Int?
  unit          String    @default("/MT")
  // Legacy display rating (string). Kept in sync with `ratingAvg` when the
  // product has real reviews, otherwise retains its cosmetic default.
  rating        String    @default("4.8")
  ratingAvg     Float?
  ratingCount   Int       @default(0)
  verified      Boolean   @default(false)
  safeDeal      Boolean   @default(true)
  isOffer       Boolean   @default(false)
  isAuction     Boolean   @default(false)
  startBidCents Int?
  // Open ascending auction knobs. `bidIncrementCents` is the minimum raise (a
  // sensible fallback is derived when null); `reserveCents` is the hidden floor
  // below which the lot doesn't sell (null = no reserve).
  bidIncrementCents Int?
  reserveCents      Int?
  auctionEndsAt DateTime?
  approved      Boolean   @default(true)
  // Moderation lifecycle (source of truth). Kept in sync with `approved`.
  status          ProductStatus @default(live)
  rejectionReason String?
  delivery      String?
  /// Category/subcategory-specific attributes captured at listing time, keyed by
  /// the field `key` from the shared attribute schema (@agrotraders/types). Scalar
  /// fields store a value; multiselect fields store an array. Buyers filter on it.
  attributes    Json?
  createdAt     DateTime  @default(now())

  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  sellerId      String?
  seller        User?        @relation("SellerProducts", fields: [sellerId], references: [id])
  marketId      String?
  market        Market?      @relation(fields: [marketId], references: [id])
  orders        Order[]
  auctionBids   AuctionBid[]
  auctionAutoBids AuctionAutoBid[]
  adCampaigns   AdCampaign[]
  buyerBids     BuyerBid[]
  reviews       Review[]     @relation("ProductReviews")
  translations  ProductTranslation[]
  /// Per-field SHA-1 of the source (English) text at last translation, so the
  /// translation worker skips fields whose source is unchanged. Keyed by field name.
  sourceHashes  Json?
}

model Order {
  id        String      @id @default(cuid())
  reference String      @unique
  /// Display strings. `me`/`admin` analytics parse these — every money-mutating
  /// path must keep writing them alongside the numeric columns below.
  amount    String
  qty       String?
  status    OrderStatus @default(processing)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt

  // Numeric source of truth for all new code.
  unitPriceCents Int?
  amountCents    Int?
  qtyValue       Float?
  qtyUnit        String? @default("MT")
  currency       String  @default("USD")
  note           String?

  // Dispatch snapshot — populated for both platform and external dispatch.
  dispatchMode     DispatchMode?
  transporterName  String?
  transporterPhone String?
  vehiclePlate     String?
  driverName       String?
  dispatchedAt     DateTime?

  /// Two-OTP handshake. `pickupOtp` is shown only to the seller, `deliveryOtp`
  /// only to the buyer; the transporter enters each to advance the order.
  pickupOtp          String?
  pickupVerifiedAt   DateTime?
  deliveryOtp        String?
  deliveryVerifiedAt DateTime?

  // Set for platform dispatch only.
  tripId String? @unique
  trip   Trip?   @relation("OrderTrip", fields: [tripId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  buyerId   String
  buyer     User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId  String
  seller    User     @relation("SellerOrders", fields: [sellerId], references: [id])

  events     OrderEvent[]
  invoices   Invoice[]
  hires      HireRequest[]
  buyerBid   BuyerBid?     @relation("BuyerBidOrder")
  loaderJobs LoaderJob[]   @relation("LoaderJobOrder")
  reviews    Review[]      @relation("OrderReviews")

  @@index([buyerId, status])
  @@index([sellerId, status])
}

/// Append-only lifecycle timeline for an order — drives the buyer/seller stepper.
model OrderEvent {
  id         String         @id @default(cuid())
  type       OrderEventType
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  note       String?
  meta       Json?
  createdAt  DateTime       @default(now())

  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorId String?
  actor   User?   @relation("OrderEventActor", fields: [actorId], references: [id])

  @@index([orderId, createdAt])
}

// ── Buyer bids / reverse auction ─────────────────────────────────

/// A buyer-posted requirement. `mode = quote` collects static seller bids;
/// `mode = auction` is a *reverse* auction where sellers underbid each other
/// and may see the current best price. This is the opposite of the sealed
/// seller-side auction (`Product.isAuction` + `AuctionBid`) — the two never mix.
model BuyerBid {
  id        String         @id @default(cuid())
  reference String         @unique
  mode      BuyerBidMode   @default(quote)
  status    BuyerBidStatus @default(open)

  title              String
  productName        String
  qtyValue           Float
  qtyUnit            String    @default("MT")
  targetPriceCents   Int?
  currency           String    @default("USD")
  deliveryPlace      String?
  destinationCountry String?
  deadline           DateTime?
  /// Countdown for `mode = auction` only.
  auctionEndsAt      DateTime?
  notes              String?
  /// Buyer-supplied reference photos of the goods wanted. Max 6, first = cover.
  images             String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  productId  String?
  product    Product?  @relation(fields: [productId], references: [id])
  buyerId    String
  buyer      User      @relation("BuyerBidBuyer", fields: [buyerId], references: [id])

  awardedSellerBidId String? @unique
  /// The Order minted from the awarded seller bid.
  orderId            String? @unique
  order              Order?  @relation("BuyerBidOrder", fields: [orderId], references: [id])

  sellerBids SellerBid[]
  translations BuyerBidTranslation[]
  /// Per-field source hash for translate-on-write skip logic (see Product.sourceHashes).
  sourceHashes Json?

  @@index([status, mode])
  @@index([buyerId])
}

model SellerBid {
  id         String          @id @default(cuid())
  priceCents Int
  qtyValue   Float
  etaDays    Int?
  message    String?
  status     SellerBidStatus @default(submitted)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt

  buyerBidId String
  buyerBid   BuyerBid @relation(fields: [buyerBidId], references: [id], onDelete: Cascade)
  sellerId   String
  seller     User     @relation("SellerBidSeller", fields: [sellerId], references: [id])

  @@index([buyerBidId, priceCents])
  @@index([sellerId])
}

// ── Invoicing ────────────────────────────────────────────────────

/// One model for every party: `issuer`/`recipient` are plain users, and the
/// billed subject is `kind` + exactly one of the nullable subject FKs.
model Invoice {
  id       String        @id @default(cuid())
  number   String        @unique
  kind     InvoiceKind
  status   InvoiceStatus @default(issued)
  currency String        @default("USD")

  subtotalCents Int
  taxCents      Int @default(0)
  totalCents    Int

  notes     String?
  issuedAt  DateTime  @default(now())
  dueAt     DateTime?
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  issuerId    String
  issuer      User   @relation("InvoiceIssuer", fields: [issuerId], references: [id])
  recipientId String
  recipient   User   @relation("InvoiceRecipient", fields: [recipientId], references: [id])

  orderId         String?
  order           Order?         @relation(fields: [orderId], references: [id])
  tripId          String?
  trip            Trip?          @relation(fields: [tripId], references: [id])
  loaderJobId     String?
  loaderJob       LoaderJob?     @relation(fields: [loaderJobId], references: [id])
  jobAssignmentId String?
  jobAssignment   JobAssignment? @relation(fields: [jobAssignmentId], references: [id])

  lines InvoiceLine[]

  @@index([issuerId])
  @@index([recipientId])
  @@index([orderId])
}

model InvoiceLine {
  id             String  @id @default(cuid())
  description    String
  qty            Float   @default(1)
  unit           String?
  unitPriceCents Int
  amountCents    Int
  sort           Int     @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

/// Monotonic sequence allocator (invoice numbering). Upsert-with-increment
/// inside the create transaction — a `count() + 1` scheme races.
model Counter {
  key   String @id
  value Int    @default(0)
}

/// A public bid on a seller's open ascending auction (`Product.isAuction`).
/// Every offer price is visible to all; only the bidder's identity is masked
/// (revealed to the seller/owner and the winning buyer). `auto = true` marks a
/// bid the proxy engine placed on a bidder's behalf up to their max.
model AuctionBid {
  id          String   @id @default(cuid())
  amountCents Int
  auto        Boolean  @default(false)
  createdAt   DateTime @default(now())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  bidderId    String
  bidder      User     @relation(fields: [bidderId], references: [id])

  @@index([productId, amountCents])
}

/// A bidder's standing proxy-bid ceiling for one auction. The engine bids the
/// minimum needed on their behalf, up to `maxCents`, whenever they're outbid.
model AuctionAutoBid {
  id        String   @id @default(cuid())
  maxCents  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])

  @@unique([productId, bidderId])
}

model KycRecord {
  id        String    @id @default(cuid())
  status    KycStatus @default(pending)
  docs      Int       @default(0)
  notes     String?
  createdAt DateTime  @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  documents KycDocument[]
}

enum KycDocType {
  trade_license
  government_id
  bank_proof
  tax_certificate
  other
}

model KycDocument {
  id           String     @id @default(cuid())
  type         KycDocType
  storageKey   String // private path e.g. kyc/<uuid>.pdf — never publicly served
  originalName String?
  mime         String
  sizeBytes    Int
  createdAt    DateTime   @default(now())

  recordId String
  record   KycRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model Office {
  id    String  @id @default(cuid())
  flag  String
  name  String
  type  String
  city  String
  mgr   String
  tz    String?
  langs String?
  staff Int     @default(0)
}

model Wallet {
  id           String     @id @default(cuid())
  balanceCents Int        @default(0)
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  txns         WalletTx[]
}

model WalletTx {
  id          String   @id @default(cuid())
  amountCents Int
  type        TxType
  note        String?
  createdAt   DateTime @default(now())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

/// A user's request to withdraw wallet funds. Created (pending) by the user;
/// an admin with `finance_manage` approves (debits the wallet + marks paid) or
/// rejects. Replaces the old instant-withdraw mock.
model PayoutRequest {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("PayoutUser", fields: [userId], references: [id])
  amountCents  Int
  status       PayoutStatus @default(pending)
  note         String?
  decidedById  String?
  decidedBy    User?        @relation("PayoutDecider", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  createdAt    DateTime     @default(now())

  @@index([userId])
  @@index([status])
}

// ── Logistics ───────────────────────────────────────────────────
model TransportRequest {
  id          String           @id @default(cuid())
  reference   String           @unique
  fromCity    String
  toCity      String
  cargo       String
  weightMt    String?
  status      RequestStatus    @default(open)
  createdAt   DateTime         @default(now())
  createdById String
  createdBy   User             @relation("RequestCreator", fields: [createdById], references: [id])
  quotes      TransportQuote[]
  trip        Trip?
}

model TransportQuote {
  id            String           @id @default(cuid())
  priceCents    Int
  etaDays       Int?
  status        QuoteStatus      @default(pending)
  createdAt     DateTime         @default(now())
  requestId     String
  request       TransportRequest @relation(fields: [requestId], references: [id])
  transporterId String
  transporter   User             @relation("QuoteTransporter", fields: [transporterId], references: [id])
}

model Vehicle {
  id              String        @id @default(cuid())
  type            String
  plate           String
  capacityMt      String?
  status          VehicleStatus @default(available)
  photoUrl        String?
  makeModel       String?
  year            Int?
  insuranceExpiry DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  ownerId         String
  owner           User          @relation(fields: [ownerId], references: [id])
  trips           Trip[]
}

model Route {
  id           String   @id @default(cuid())
  name         String
  fromCity     String
  toCity       String
  fromCountry  String?
  toCountry    String?
  distanceKm   Int?
  baseRateCents Int?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  trips        Trip[]
}

model Trip {
  id            String            @id @default(cuid())
  reference     String            @unique
  fromCity      String
  toCity        String
  cargo         String
  status        TripStatus        @default(pending)
  otp           String?
  createdAt     DateTime          @default(now())
  transporterId String
  transporter   User              @relation("TripTransporter", fields: [transporterId], references: [id])
  requestId     String?           @unique
  request       TransportRequest? @relation(fields: [requestId], references: [id])
  vehicleId     String?
  vehicle       Vehicle?          @relation(fields: [vehicleId], references: [id])
  routeId       String?
  route         Route?            @relation(fields: [routeId], references: [id])
  /// Set when this trip was created by an order dispatch. OTPs for that
  /// handshake live on the Order (external dispatch has no Trip), so `otp`
  /// above stays reserved for the standalone hire/quote flows.
  order         Order?            @relation("OrderTrip")
  invoices      Invoice[]
  reviews       Review[]          @relation("TripReviews")
}

// ── Loaders / workforce ─────────────────────────────────────────
model Team {
  id         String         @id @default(cuid())
  name       String
  createdAt  DateTime       @default(now())
  loadercoId String
  loaderco   User           @relation(fields: [loadercoId], references: [id])
  workers    Worker[]
  reviews    LoaderReview[]
}

model Worker {
  id           String          @id @default(cuid())
  name         String
  rating       String?
  status       WorkerStatus    @default(available)
  // Loader-captured details for the crew roster.
  phone          String?
  skill          String?
  dailyWageCents Int?
  // Where the worker is based and the free-text city/country tags they work in,
  // plus the minimum job length (hours) they accept. Captured at self-signup and
  // by the loader company when adding crew, so every worker in the directory is
  // filterable by location.
  originCity          String?
  originCountry       String?
  operatingCities     String[]        @default([])
  operatingCountries  String[]        @default([])
  minWorkHours        Int?
  createdAt    DateTime        @default(now())
  // Optional: self-registered workers have no loader company until hired.
  loadercoId   String?
  loaderco     User?           @relation("LoadercoWorkers", fields: [loadercoId], references: [id])
  teamId       String?
  team         Team?           @relation(fields: [teamId], references: [id])
  userId       String?         @unique
  user         User?           @relation("WorkerUser", fields: [userId], references: [id])
  assignments  JobAssignment[]
  attendance   Attendance[]
  hireRequests HireRequest[]
}

model LoaderJob {
  id            String          @id @default(cuid())
  reference     String          @unique
  location      String
  workersNeeded Int             @default(1)
  status        JobStatus       @default(open)
  otp           String?
  payCents      Int?
  /// Context carried over from the hire / order so the loader sees what the
  /// job is for. `orderId` links back to the sourcing order when there is one.
  cargo         String?
  neededDate    DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  createdById   String
  createdBy     User            @relation("JobCreator", fields: [createdById], references: [id])
  loadercoId    String?
  loaderco      User?           @relation("JobLoaderco", fields: [loadercoId], references: [id])
  orderId       String?
  order         Order?          @relation("LoaderJobOrder", fields: [orderId], references: [id])
  assignments   JobAssignment[]
  attendance    Attendance[]
  invoices      Invoice[]
  reviews       LoaderReview[]
  unifiedReviews Review[]       @relation("LoaderJobReviews")
}

model JobAssignment {
  id        String           @id @default(cuid())
  status    AssignmentStatus @default(assigned)
  createdAt DateTime         @default(now())
  jobId     String
  job       LoaderJob        @relation(fields: [jobId], references: [id])
  workerId  String
  worker    Worker           @relation(fields: [workerId], references: [id])
  invoices  Invoice[]
  reviews   Review[]         @relation("AssignmentReviews")

  @@unique([jobId, workerId])
}

model Attendance {
  id         String    @id @default(cuid())
  checkInAt  DateTime?
  checkOutAt DateTime?
  date       DateTime  @default(now())
  /// Loader-company user who captured this row; null when the worker self-checked-in.
  recordedById String?
  recordedBy   User?   @relation("AttendanceRecorder", fields: [recordedById], references: [id])
  jobId      String
  job        LoaderJob @relation(fields: [jobId], references: [id])
  workerId   String
  worker     Worker    @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([jobId])
}

// ── Dashboard features (persisted, replacing former client-side demos) ──

enum DriverStatus {
  active
  off
}

/// A seller-funded promotion boosting one of their listings. Admin sees all.
/// A campaign is LIVE only when `status = approved` AND `active` AND its product
/// is approved. `active` is the seller's pause/resume switch; `status` is the
/// admin's moderation gate. Pausing must never require re-approval.
model AdCampaign {
  id               String    @id @default(cuid())
  sellerId         String
  seller           User      @relation("AdSeller", fields: [sellerId], references: [id])
  productId        String
  product          Product   @relation(fields: [productId], references: [id])
  dailyBudgetCents Int
  active           Boolean   @default(true)
  status           AdStatus  @default(pending)
  // Delivery metrics, incremented as the promoted product is served/clicked.
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  rejectionReason  String?
  reviewedAt       DateTime?
  reviewedById     String?
  reviewedBy       User?     @relation("AdReviewer", fields: [reviewedById], references: [id])
  createdAt        DateTime  @default(now())

  @@index([sellerId])
  @@index([productId])
  @@index([status, active])
}

/// A transporter's driver roster with reliability metrics.
model Driver {
  id               String       @id @default(cuid())
  ownerId          String
  owner            User         @relation(fields: [ownerId], references: [id])
  name             String
  vehicle          String?
  ratingPct        Int?
  onTimePct        Int?
  status           DriverStatus @default(active)
  photoUrl         String?
  phone            String?
  licenseNumber    String?
  licenseExpiry    DateTime?
  experienceYears  Int?
  ratePerHourCents Int?
  createdAt        DateTime     @default(now())

  @@index([ownerId])
}

/// A loader company's weekly crew-availability grid (one row per day+slot).
model CrewAvailability {
  id         String  @id @default(cuid())
  loadercoId String
  loaderco   User    @relation(fields: [loadercoId], references: [id])
  weekday    Int // 0 (Sun) – 6 (Sat)
  slot       String // e.g. "morning" | "afternoon" | "evening"
  available  Boolean @default(true)

  @@unique([loadercoId, weekday, slot])
  @@index([loadercoId])
}

/// A loader company's editable per-service rate card (shown on the dashboard).
model LoaderRate {
  id         String   @id @default(cuid())
  loadercoId String
  loaderco   User     @relation("LoaderRates", fields: [loadercoId], references: [id])
  service    String
  rateCents  Int
  unit       String   @default("MT")
  createdAt  DateTime @default(now())

  @@index([loadercoId])
}

/// A client's star rating of a loader company after a completed job.
model LoaderReview {
  id         String     @id @default(cuid())
  loadercoId String
  loaderco   User       @relation("LoaderReviewsForCo", fields: [loadercoId], references: [id])
  raterId    String
  rater      User       @relation("LoaderReviewsByUser", fields: [raterId], references: [id])
  jobId      String?
  job        LoaderJob? @relation(fields: [jobId], references: [id])
  teamId     String?
  team       Team?      @relation(fields: [teamId], references: [id])
  stars      Int
  text       String?
  createdAt  DateTime   @default(now())

  @@index([loadercoId])
}

/// Unified two-way star review left after a service completes. Polymorphic over
/// the reviewed subject via `kind` + exactly one matching nullable FK (mirrors
/// the Invoice precedent). Immutable to the reviewee; the author may edit their
/// own row at any time; only admins can hide/remove/delete (audited).
model Review {
  id           String       @id @default(cuid())
  kind         ReviewKind
  revieweeRole ReviewRole
  /// Scalar mirror of the underlying subject id (order/trip/job/assignment/hire).
  /// Always set — powers the uniqueness gate and fast lookups.
  subjectId    String
  stars        Int
  text         String?

  status          ReviewStatus @default(visible)
  adminNote       String?
  editedByAdminId String?
  editedByAdmin   User?        @relation("ReviewAdminEditor", fields: [editedByAdminId], references: [id])
  /// Set whenever the author self-edits (kept distinct from admin edits).
  editedByAuthorAt DateTime?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  raterId      String
  rater        User         @relation("ReviewsAuthored", fields: [raterId], references: [id])
  revieweeId   String
  reviewee     User         @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  // Typed nullable subject FKs — exactly the one matching `kind` is set.
  orderId         String?
  order           Order?         @relation("OrderReviews", fields: [orderId], references: [id])
  tripId          String?
  trip            Trip?          @relation("TripReviews", fields: [tripId], references: [id])
  loaderJobId     String?
  loaderJob       LoaderJob?     @relation("LoaderJobReviews", fields: [loaderJobId], references: [id])
  jobAssignmentId String?
  jobAssignment   JobAssignment? @relation("AssignmentReviews", fields: [jobAssignmentId], references: [id])
  hireRequestId   String?
  hireRequest     HireRequest?   @relation("HireReviews", fields: [hireRequestId], references: [id])
  productId       String?
  product         Product?       @relation("ProductReviews", fields: [productId], references: [id])

  translations    ReviewTranslation[]
  /// Per-field source hash for translate-on-write skip logic (see Product.sourceHashes).
  sourceHashes    Json?

  // One review per (subject, author, target-role): allows both directions
  // (different rater) and the order seller+product facets (different role).
  @@unique([kind, subjectId, raterId, revieweeRole])
  @@index([revieweeId, status])
  @@index([productId, status])
  @@index([kind, status])
}

/// Editable public site pages managed from the admin CMS section.
model CmsPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String?
  published Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  translations CmsPageTranslation[]
}

/// Admin-uploaded brand assets. Singleton — always row id = 1. A null column
/// means "fall back to the built-in default", so the apps never depend on an
/// upload having happened.
model Branding {
  id         Int      @id @default(1)
  logoUrl    String?
  appIconUrl String?
  faviconUrl String?
  updatedAt  DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════════
//  CHAT SYSTEM 1 — AGROTRADERS COMMUNITY (public marketplace chat)
//  Kept strictly separate from Live Support (System 2) in models/enums.
// ════════════════════════════════════════════════════════════════════

enum CommunityGroupKind {
  channel
  topic
  regional
  crop
  buyer_requirement
  seller_offer
  transport
  loader
  warehousing
  market_prices
  international
  custom
}

enum CommunityGroupVisibility {
  public
  private
  invite_only
}

enum CommunityMemberRole {
  owner
  admin
  member
}

enum CommunityPostType {
  discussion
  trade_requirement
  offer
  question
}

enum CommunityReportStatus {
  open
  reviewing
  actioned
  dismissed
}

enum CommunityReportTargetType {
  post
  message
  user
  group
}

model CommunityGroup {
  id          String                   @id @default(cuid())
  slug        String                   @unique
  name        String
  description String?
  kind        CommunityGroupKind       @default(custom)
  visibility  CommunityGroupVisibility @default(public)
  emoji       String?
  region      String?
  cropTag     String?
  isDefault   Boolean                  @default(false)
  ownerId     String?
  owner       User?                    @relation("CommunityGroupOwner", fields: [ownerId], references: [id])
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  deletedAt   DateTime?

  members      CommunityGroupMember[]
  posts        CommunityPost[]
  messages     CommunityMessage[]
  translations CommunityGroupTranslation[]

  @@index([kind])
  @@index([visibility])
}

model CommunityGroupMember {
  id         String              @id @default(cuid())
  groupId    String
  group      CommunityGroup      @relation(fields: [groupId], references: [id])
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  role       CommunityMemberRole @default(member)
  lastReadAt DateTime?
  createdAt  DateTime            @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model CommunityPost {
  id        String            @id @default(cuid())
  groupId   String?
  group     CommunityGroup?   @relation(fields: [groupId], references: [id])
  authorId  String
  author    User              @relation(fields: [authorId], references: [id])
  type      CommunityPostType @default(discussion)
  title     String?
  body      String
  pinned    Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?

  requirement CommunityTradeRequirement?
  savedBy     CommunitySavedPost[]
  translations CommunityPostTranslation[]
  /// Per-field source hash for translate-on-write skip logic (see Product.sourceHashes).
  sourceHashes Json?

  @@index([groupId])
  @@index([authorId])
  @@index([type])
}

model CommunityTradeRequirement {
  id                 String                   @id @default(cuid())
  postId             String                   @unique
  post               CommunityPost            @relation(fields: [postId], references: [id])
  authorId           String
  author             User                     @relation(fields: [authorId], references: [id])
  title              String
  productCategory    String
  productName        String
  quantity           String
  unit               String
  grade              String?
  budget             String?
  buyerLocation      String?
  destinationCountry String?
  delivery           String?
  neededDate         DateTime?
  transportRequired  Boolean                  @default(false)
  loaderRequired     Boolean                  @default(false)
  importExport       Boolean                  @default(false)
  visibility         CommunityGroupVisibility @default(public)
  expiryDate         DateTime?
  createdAt          DateTime                 @default(now())

  responses CommunityRequirementResponse[]
  translations CommunityTradeRequirementTranslation[]
  /// Per-field source hash for translate-on-write skip logic (see Product.sourceHashes).
  sourceHashes Json?

  @@index([authorId])
  @@index([productCategory])
}

model CommunityRequirementResponse {
  id            String                    @id @default(cuid())
  requirementId String
  requirement   CommunityTradeRequirement @relation(fields: [requirementId], references: [id])
  responderId   String
  responder     User                      @relation(fields: [responderId], references: [id])
  kind          String                    @default("offer")
  body          String
  priceText     String?
  quantityText  String?
  deliveryText  String?
  productId     String?
  createdAt     DateTime                  @default(now())

  @@index([requirementId])
}

model CommunityDirectThread {
  id            String    @id @default(cuid())
  aId           String
  a             User      @relation("DmA", fields: [aId], references: [id])
  bId           String
  b             User      @relation("DmB", fields: [bId], references: [id])
  lastMessageAt DateTime?
  aLastReadAt   DateTime?
  bLastReadAt   DateTime?
  createdAt     DateTime  @default(now())

  messages CommunityMessage[]

  @@unique([aId, bId])
  @@index([bId])
}

model CommunityMessage {
  id        String                 @id @default(cuid())
  groupId   String?
  group     CommunityGroup?        @relation(fields: [groupId], references: [id])
  threadId  String?
  thread    CommunityDirectThread? @relation(fields: [threadId], references: [id])
  senderId  String
  sender    User                   @relation(fields: [senderId], references: [id])
  body      String
  replyToId String?
  replyTo   CommunityMessage?      @relation("CommunityMessageReplies", fields: [replyToId], references: [id])
  replies   CommunityMessage[]     @relation("CommunityMessageReplies")
  pinned    Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  deletedAt DateTime?
  /// Detected source language of `body` (BCP-47-ish), set once on send. Drives
  /// lazy translate-on-read: a viewer whose locale differs gets a cached translation.
  sourceLang String?

  reactions    CommunityMessageReaction[]
  attachments  ChatAttachment[]
  translations CommunityMessageTranslation[]

  @@index([groupId, createdAt])
  @@index([threadId, createdAt])
  @@index([senderId])
}

model CommunityMessageReaction {
  id        String           @id @default(cuid())
  messageId String
  message   CommunityMessage @relation(fields: [messageId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime         @default(now())

  @@unique([messageId, userId, emoji])
}

model CommunityReport {
  id             String                    @id @default(cuid())
  reporterId     String
  reporter       User                      @relation("CommunityReporter", fields: [reporterId], references: [id])
  targetType     CommunityReportTargetType
  targetId       String
  reason         String
  status         CommunityReportStatus     @default(open)
  reviewedById   String?
  reviewedBy     User?                     @relation("CommunityReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime                  @default(now())

  @@index([status])
  @@index([targetType, targetId])
}

model CommunityUserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model CommunitySavedPost {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([userId, postId])
}

// ════════════════════════════════════════════════════════════════════
//  CHAT SYSTEM 2 — LIVE SUPPORT (private 1:1 customer support)
//  Kept strictly separate from Community (System 1) in models/enums.
// ════════════════════════════════════════════════════════════════════

enum SupportCategory {
  account_kyc
  product_listing
  buyer_order
  seller_order
  payment_safedeal
  wallet_payout
  auction_bid
  transport
  loader
  import_export
  technical
  global_office
  other
}

enum SupportStatus {
  new
  waiting_support
  assigned
  in_progress
  waiting_user
  escalated
  resolved
  closed
}

enum SupportPriority {
  low
  medium
  high
  urgent
}

enum SupportAuthorType {
  user
  agent
  system
}

enum AgentAvailability {
  online
  away
  offline
}

model SupportTicket {
  id                 String          @id @default(cuid())
  reference          String          @unique
  userId             String
  user               User            @relation(fields: [userId], references: [id])
  category           SupportCategory
  subject            String
  status             SupportStatus   @default(new)
  priority           SupportPriority @default(medium)
  language           String          @default("en")
  country            String?
  orderId            String?
  productId          String?
  auctionId          String?
  transportBookingId String?
  loaderBookingId    String?
  safeDealTxId       String?
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  conversation SupportConversation?
  assignments  SupportTicketAssignment[]
  notes        SupportInternalNote[]
  tags         SupportTicketTag[]
  rating       SupportRating?
  sla          SupportSLA?

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([userId])
}

model SupportConversation {
  id        String        @id @default(cuid())
  ticketId  String        @unique
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  createdAt DateTime      @default(now())

  messages SupportMessage[]
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id])
  authorId       String?
  author         User?               @relation(fields: [authorId], references: [id])
  authorType     SupportAuthorType   @default(user)
  body           String
  readByUserAt   DateTime?
  readByAgentAt  DateTime?
  createdAt      DateTime            @default(now())
  deletedAt      DateTime?

  attachments ChatAttachment[]

  @@index([conversationId, createdAt])
}

model SupportTicketAssignment {
  id           String        @id @default(cuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id])
  agentId      String
  agent        User          @relation("AssignmentAgent", fields: [agentId], references: [id])
  assignedById String?
  assignedBy   User?         @relation("AssignmentAssigner", fields: [assignedById], references: [id])
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  unassignedAt DateTime?

  @@index([ticketId])
  @@index([agentId])
}

model SupportAgent {
  id           String            @id @default(cuid())
  userId       String            @unique
  user         User              @relation(fields: [userId], references: [id])
  availability AgentAvailability @default(offline)
  activeCount  Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model SupportInternalNote {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

model SupportTag {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  tickets      SupportTicketTag[]
  translations SupportTagTranslation[]
}

model SupportTicketTag {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  tagId     String
  tag       SupportTag    @relation(fields: [tagId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([ticketId, tagId])
}

model SupportSLA {
  id                    String        @id @default(cuid())
  ticketId              String        @unique
  ticket                SupportTicket @relation(fields: [ticketId], references: [id])
  firstResponseDueAt    DateTime
  resolutionDueAt       DateTime
  firstResponseBreached Boolean       @default(false)
  resolutionBreached    Boolean       @default(false)
  createdAt             DateTime      @default(now())
}

model SupportRating {
  id        String        @id @default(cuid())
  ticketId  String        @unique
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  score     Int
  comment   String?
  createdAt DateTime      @default(now())
}

// ════════════════════════════════════════════════════════════════════
//  SHARED (neutral) — used by BOTH systems via a `system` discriminator.
// ════════════════════════════════════════════════════════════════════

model ChatAttachment {
  id                 String            @id @default(cuid())
  system             String
  uploaderId         String
  uploader           User              @relation(fields: [uploaderId], references: [id])
  kind               String            @default("document")
  mime               String
  sizeBytes          Int
  s3Key              String
  originalName       String?
  communityMessageId String?
  communityMessage   CommunityMessage? @relation(fields: [communityMessageId], references: [id])
  supportMessageId   String?
  supportMessage     SupportMessage?   @relation(fields: [supportMessageId], references: [id])
  createdAt          DateTime          @default(now())

  @@index([communityMessageId])
  @@index([supportMessageId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  system    String
  type      String
  /// Server-rendered title/body in the recipient's locale (from `User.locale`,
  /// English fallback). Kept so push/email and un-updated clients show correct
  /// text; clients that know the type re-render live from `params` + the
  /// `notification` i18n namespace so switching UI language re-localizes them.
  title     String
  body      String?
  /// Interpolation params for the `notification:<type>` template (reference,
  /// status, amount, counterparty, …). Lets clients re-render on locale switch.
  params    Json?
  data      Json?
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

/// A registered push destination for a user. `token` is an FCM registration
/// token — web (Firebase JS SDK `getToken` with a VAPID key) and mobile
/// (@react-native-firebase/messaging) both produce FCM tokens, so one table
/// serves every platform. Tokens are pruned when FCM reports them invalid.
model DeviceToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   String   // 'web' | 'android' | 'ios'
  token      String   @unique
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// ════════════════════════════════════════════════════════════════════
//  LABEL TRANSLATIONS
//
//  The base row always holds the canonical English text, so existing
//  queries keep working untouched. These tables hold NON-ENGLISH rows
//  only; a missing row means "fall back to the base row".
// ════════════════════════════════════════════════════════════════════

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

model SubcategoryTranslation {
  id            String      @id @default(cuid())
  subcategoryId String
  locale        String
  name          String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([subcategoryId, locale])
  @@index([locale])
}

model MarketTranslation {
  id       String  @id @default(cuid())
  marketId String
  locale   String
  name     String
  city     String?
  region   String?
  market   Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, locale])
  @@index([locale])
}

model CmsPageTranslation {
  id        String  @id @default(cuid())
  cmsPageId String
  locale    String
  title     String
  body      String?
  cmsPage   CmsPage @relation(fields: [cmsPageId], references: [id], onDelete: Cascade)

  @@unique([cmsPageId, locale])
  @@index([locale])
}

model SupportTagTranslation {
  id           String     @id @default(cuid())
  supportTagId String
  locale       String
  label        String
  supportTag   SupportTag @relation(fields: [supportTagId], references: [id], onDelete: Cascade)

  @@unique([supportTagId, locale])
  @@index([locale])
}

model CommunityGroupTranslation {
  id          String         @id @default(cuid())
  groupId     String
  locale      String
  name        String
  description String?
  group       CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, locale])
  @@index([locale])
}

// ── User-generated content translations (translate-on-write + cache) ──────
// Base rows hold canonical English; a translation row exists per non-English
// locale that has been machine-translated. Missing row → English shows through
// (via localize() in common/locale.ts).

model ProductTranslation {
  id        String  @id @default(cuid())
  productId String
  locale    String
  name      String
  grade     String?
  origin    String?
  qty       String?
  moq       String?
  delivery  String?
  /// Translated human-readable attribute values (text/select/multiselect), keyed
  /// by the same attribute keys as Product.attributes. Non-text values are omitted.
  attributes Json?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
}

model ReviewTranslation {
  id       String @id @default(cuid())
  reviewId String
  locale   String
  text     String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, locale])
  @@index([locale])
}

model CommunityPostTranslation {
  id     String        @id @default(cuid())
  postId String
  locale String
  title  String?
  body   String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([locale])
}

model CommunityTradeRequirementTranslation {
  id            String                    @id @default(cuid())
  requirementId String
  locale        String
  title         String
  productName   String
  grade         String?
  delivery      String?
  requirement   CommunityTradeRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, locale])
  @@index([locale])
}

model BuyerBidTranslation {
  id          String   @id @default(cuid())
  bidId       String
  locale      String
  title       String
  productName String
  notes       String?
  bid         BuyerBid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, locale])
  @@index([locale])
}

model CommunityMessageTranslation {
  id        String           @id @default(cuid())
  messageId String
  locale    String
  body      String
  createdAt DateTime         @default(now())
  message   CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, locale])
  @@index([locale])
}

/// Generic machine-translation cache keyed by the SHA-1 of the source (English)
/// text + target locale — not by any owning row. It is the universal safety net
/// behind `TextTranslationService.localizeMany`: any free-text field on any model
/// (orders, auctions, hires, ads, transport, markets, support, directory bios, …)
/// is translated once, stored here, and reused on every later read. Identical
/// source strings share a single row across all content types, so repeated copy
/// ("Order dispatched", a city name) is translated once globally. Rows are never
/// invalidated — a changed source produces a new hash and a new row.
model TextTranslation {
  id         String   @id @default(cuid())
  /// SHA-1 hex of the canonical English source string.
  sourceHash String
  locale     String
  text       String
  createdAt  DateTime @default(now())

  @@unique([sourceHash, locale])
  @@index([locale])
}
