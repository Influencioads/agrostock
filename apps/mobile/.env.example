# Copy to .env (gitignored) and fill in. Expo auto-loads .env for both the JS
# bundle (EXPO_PUBLIC_* vars) and app.config.js evaluation (all vars).

# Local dev API — the LAN IP of the machine running apps/api (not localhost, the
# emulator/device can't reach that). EXPO_PUBLIC_* is inlined into the JS bundle.
EXPO_PUBLIC_API_URL=http://192.168.1.12:3100

# Google Maps key for react-native-maps. Injected into native build config by
# app.config.js (Android manifest + iOS). NOT public-prefixed — not needed in JS.
# For EAS cloud builds set it as a secret instead of committing:
#   eas secret:create --scope project --name GOOGLE_MAPS_API_KEY --value <key>
# It ships in the app binary, so restrict the key in the Google Cloud console
# (Android: package + SHA-1 fingerprint; iOS: bundle id; limit to the Maps SDKs).
GOOGLE_MAPS_API_KEY=
