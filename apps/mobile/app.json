{
  "expo": {
    "name": "AgroTraders",
    "slug": "agrotraders",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "agrotraders",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3D2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrotraders.org"
    },
    "android": {
      "package": "com.agrotraders.org",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#178E4B"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-build-properties",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#178E4B"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3ee3e712-ea7d-4a74-972e-cbeb6b625399"
      }
    },
    "owner": "influencioads"
  }
}
