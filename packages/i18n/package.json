{
  "name": "@agrotraders/i18n",
  "version": "0.1.0",
  "private": true,
  "description": "Shared message catalogs and i18next setup for AgroTraders (web, admin, mobile, api).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./notifications": {
      "types": "./src/notifications.ts",
      "node": "./dist/notifications.js",
      "default": "./src/notifications.ts"
    },
    "./init-web": "./src/init-web.ts",
    "./init-admin": "./src/init-admin.ts",
    "./init-native": "./src/init-native.ts",
    "./locales/*": "./locales/*"
  },
  "typesVersions": {
    "*": {
      "notifications": ["./src/notifications.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').writeFileSync('dist/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "check-hardcoded": "node scripts/check-hardcoded.mjs",
    "check-usage": "node scripts/check-usage.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^23.16.8"
  },
  "peerDependencies": {
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-resources-to-backend": "^1.2.1"
  },
  "peerDependenciesMeta": {
    "i18next-browser-languagedetector": {
      "optional": true
    },
    "i18next-resources-to-backend": {
      "optional": true
    }
  },
  "devDependencies": {
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1"
  }
}
